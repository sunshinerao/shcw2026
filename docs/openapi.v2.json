  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authorization: Bearer sk_oc_..."
      },
      "xApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "x-api-key: sk_oc_..."
      }
    },
    "headers": {
      "XApiVersion": {
        "description": "API version marker",
        "schema": {
          "type": "string",
          "enum": ["v2"]
        }
      }
    },
    "responses": {
      "ErrorBadRequest": {
        "description": "Bad Request",
        "headers": { "X-API-Version": { "$ref": "#/components/headers/XApiVersion" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "success": false, "error": "Invalid request", "code": "BAD_REQUEST" } } }
      },
      "ErrorUnauthorized": {
        "description": "Unauthorized",
        "headers": { "X-API-Version": { "$ref": "#/components/headers/XApiVersion" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "success": false, "error": "Unauthorized", "code": "UNAUTHORIZED" } } }
      },
      "ErrorForbidden": {
        "description": "Forbidden",
        "headers": { "X-API-Version": { "$ref": "#/components/headers/XApiVersion" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "success": false, "error": "Forbidden", "code": "FORBIDDEN" } } }
      },
      "ErrorNotFound": {
        "description": "Not Found",
        "headers": { "X-API-Version": { "$ref": "#/components/headers/XApiVersion" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "success": false, "error": "Not found", "code": "NOT_FOUND" } } }
      },
      "ErrorConflict": {
        "description": "Conflict",
        "headers": { "X-API-Version": { "$ref": "#/components/headers/XApiVersion" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "success": false, "error": "Conflict", "code": "CONFLICT" } } }
      },
      "ErrorInternal": {
        "description": "Internal Server Error",
        "headers": { "X-API-Version": { "$ref": "#/components/headers/XApiVersion" } },
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "success": false, "error": "Internal server error", "code": "INTERNAL_ERROR" } } }
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "required": ["success"],
        "properties": {
          "success": { "type": "boolean", "const": true },
          "message": { "type": "string" },
          "data": {}
        },
        "additionalProperties": true
      },
      "PaginatedSuccessResponse": {
        "type": "object",
        "required": ["success"],
        "properties": {
          "success": { "type": "boolean", "const": true },
          "data": {},
          "pagination": {
            "type": "object",
            "properties": {
              "page": { "type": "integer" },
              "pageSize": { "type": "integer" },
              "total": { "type": "integer" },
              "totalPages": { "type": "integer" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["success", "error", "code"],
        "properties": {
          "success": { "type": "boolean", "const": false },
          "error": { "type": "string" },
          "code": { "type": "string" }
        },
        "additionalProperties": true
      },
      "EventType": {
        "type": "string",
        "enum": ["forum", "workshop", "ceremony", "conference", "networking"]
      },
      "PartnerTier": {
        "type": "string",
        "enum": ["platinum", "gold", "silver", "bronze", "partner"]
      },
      "KnowledgeAssetType": {
        "type": "string",
        "enum": ["WHITE_PAPER", "REPORT", "INITIATIVE", "POLICY_BRIEF", "GUIDE", "DECLARATION", "SUMMARY"]
      },
      "PublishStatus": {
        "type": "string",
        "enum": ["DRAFT", "PUBLISHED"]
      },
      "AccessType": {
        "type": "string",
        "enum": ["PUBLIC", "LOGIN_REQUIRED", "PAID", "HIDDEN"]
      },
      "OrgType": {
        "type": "string",
        "enum": ["ngo", "gov", "corp", "academic", "media", "community", "foundation", "intergovernmental"]
      },
      "EventUpsertRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "titleEn": { "type": "string" },
          "description": { "type": "string" },
          "descriptionEn": { "type": "string" },
          "shortDesc": { "type": "string" },
          "shortDescEn": { "type": "string" },
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "startTime": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
          "endTime": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
          "venue": { "type": "string" },
          "venueEn": { "type": "string" },
          "address": { "type": "string" },
          "addressEn": { "type": "string" },
          "city": { "type": "string" },
          "cityEn": { "type": "string" },
          "type": { "$ref": "#/components/schemas/EventType" },
          "trackId": { "type": "string" },
          "maxAttendees": { "type": "integer" },
          "isPublished": { "type": "boolean" },
          "isFeatured": { "type": "boolean" },
          "isPinned": { "type": "boolean" },
          "requireApproval": { "type": "boolean" },
          "isClosed": { "type": "boolean" },
          "eventDateSlots": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "scheduleDate": { "type": "string", "format": "date" },
                "startTime": { "type": "string" },
                "endTime": { "type": "string" }
              },
              "required": ["scheduleDate", "startTime", "endTime"]
            }
          }
        },
        "additionalProperties": true
      },
      "AgendaUpsertRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "titleEn": { "type": "string" },
          "description": { "type": "string" },
          "descriptionEn": { "type": "string" },
          "agendaDate": { "type": "string", "format": "date" },
          "startTime": { "type": "string" },
          "endTime": { "type": "string" },
          "type": { "type": "string", "enum": ["keynote", "panel", "workshop", "sharing", "launch", "break", "networking"] },
          "venue": { "type": "string" },
          "order": { "type": "integer" },
          "speakerIds": { "type": "array", "items": { "type": "string" } },
          "moderatorId": { "type": "string" }
        },
        "additionalProperties": true
      },
      "SpeakerUpsertRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "nameEn": { "type": "string" },
          "salutation": { "type": "string" },
          "title": { "type": "string" },
          "titleEn": { "type": "string" },
          "organization": { "type": "string" },
          "organizationEn": { "type": "string" },
          "organizationLogo": { "type": "string" },
          "bio": { "type": "string" },
          "bioEn": { "type": "string" },
          "avatar": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "linkedin": { "type": "string" },
          "twitter": { "type": "string" },
          "website": { "type": "string" },
          "isKeynote": { "type": "boolean" },
          "order": { "type": "integer" }
        },
        "additionalProperties": true
      },
      "NewsUpsertRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "titleEn": { "type": "string" },
          "slug": { "type": "string" },
          "excerpt": { "type": "string" },
          "excerptEn": { "type": "string" },
          "content": { "type": "string" },
          "contentEn": { "type": "string" },
          "coverImage": { "type": "string" },
          "isPublished": { "type": "boolean" }
        },
        "additionalProperties": true
      },
      "PartnerUpsertRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "nameEn": { "type": "string" },
          "logo": { "type": "string" },
          "website": { "type": "string" },
          "description": { "type": "string" },
          "descriptionEn": { "type": "string" },
          "tier": { "$ref": "#/components/schemas/PartnerTier" },
          "order": { "type": "integer" },
          "isActive": { "type": "boolean" },
          "showOnHomepage": { "type": "boolean" }
        },
        "additionalProperties": true
      },
      "InsightUpsertRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "titleEn": { "type": "string" },
          "slug": { "type": "string" },
          "type": { "$ref": "#/components/schemas/KnowledgeAssetType" },
          "status": { "$ref": "#/components/schemas/PublishStatus" },
          "accessType": { "$ref": "#/components/schemas/AccessType" },
          "publishDate": { "type": "string", "format": "date-time" },
          "summary": { "type": "string" },
          "summaryEn": { "type": "string" },
          "content": { "type": "string" },
          "contentEn": { "type": "string" },
          "fileUrl": { "type": "string" },
          "price": { "type": "number" },
          "currency": { "type": "string" },
          "relatedEventIds": { "type": "array", "items": { "type": "string" } },
          "relatedInstitutionIds": { "type": "array", "items": { "type": "string" } },
          "relatedSpeakerIds": { "type": "array", "items": { "type": "string" } },
          "relatedTrackIds": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      },
      "InstitutionUpsertRequest": {
        "type": "object",
        "properties": {
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "nameEn": { "type": "string" },
          "shortName": { "type": "string" },
          "shortNameEn": { "type": "string" },
          "logo": { "type": "string" },
          "website": { "type": "string" },
          "orgType": { "$ref": "#/components/schemas/OrgType" },
          "countryOrRegion": { "type": "string" },
          "countryOrRegionEn": { "type": "string" },
          "description": { "type": "string" },
          "descriptionEn": { "type": "string" },
          "collaborationBg": { "type": "string" },
          "collaborationBgEn": { "type": "string" },
          "isActive": { "type": "boolean" },
          "order": { "type": "integer" }
        },
        "additionalProperties": true
      }
    }
  }
}
