generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户角色枚举
enum UserRole {
  VISITOR       // 访客（未注册用户）
  ATTENDEE      // 参会观众
  ORGANIZATION  // 机构代表
  SPONSOR       // 赞助商
  SPEAKER       // 演讲嘉宾
  MEDIA         // 媒体
  ADMIN         // 管理员
  EVENT_MANAGER // 活动管理员
  SPECIAL_PASS_MANAGER // 特别通行证管理员
  STAFF         // 工作人员
  VERIFIER      // 现场验证人员
}

// 用户状态枚举
enum UserStatus {
  PENDING   // 待审核
  ACTIVE    // 已激活
  SUSPENDED // 已禁用
}

// 报名表状态枚举
enum RegistrationStatus {
  PENDING_APPROVAL // 待审批
  REGISTERED       // 已批准/已报名
  CANCELLED        // 已取消
  ATTENDED         // 已入场
  WAITLIST         // 候补名单
  REJECTED         // 已拒绝
}

// 活动维度：层级分类
enum EventLayer {
  INSTITUTION    // 制度层
  ECONOMY        // 经济层
  ROOT           // 根源层
  ACCELERATOR    // 加速器
  COMPREHENSIVE  // 综合
}

// 活动维度：主办类型
enum EventHostType {
  OFFICIAL       // 官方活动
  CO_HOSTED      // 联合主办活动
  REGISTERED     // 注册活动
  SIDE_EVENT     // 边会活动
  COMMUNITY      // 社区活动
}

// 联系留言分类
enum ContactCategory {
  GENERAL       // 一般咨询
  ORGANIZATION  // 机构代表
  PARTNERSHIP   // 合作伙伴申请
  SPEAKER       // 嘉宾申请
  MEDIA         // 媒体合作
  SPONSOR       // 赞助咨询
  VOLUNTEER     // 志愿者申请
  OTHER         // 其他
}

// 联系留言状态
enum ContactMessageStatus {
  PENDING    // 待处理
  REPLIED    // 已回复
  CLOSED     // 已关闭
}

// 邀请函申请状态
enum InvitationStatus {
  PENDING      // 待处理
  UPLOADED     // 已上传
  DOWNLOADED   // 已下载
  REJECTED     // 已拒绝
}

enum KnowledgeAssetType {
  WHITE_PAPER
  REPORT
  INITIATIVE
  POLICY_BRIEF
  GUIDE
  DECLARATION
  SUMMARY
}

enum AccessType {
  PUBLIC
  LOGIN_REQUIRED
  PAID
  HIDDEN
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum PosterTemplateType {
  EVENT
  SPEAKER
  AGENDA
  SOCIAL_CARD
  KNOWLEDGE
}

enum PosterJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// 知识成果文档模格式
enum KnowledgeDocumentFormat {
  PDF
  DOCX
}

// 知识成果模版类型
enum KnowledgeTemplateType {
  FORMAL_DOCUMENT    // 正式文档（PDF编订）
  WEBPAGE_DISPLAY    // 网页展示
}

// 用户表
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String    // bcrypt加密
  name          String
  salutation    String?   // 称谓: Dr. / Mr. / Ms. / Prof. 等
  avatar        String?   // 头像URL
  phone         String?   // 手机号
  title         String?   // 职位
  bio           String?   @db.Text // 个人简介
  country       String?   // 国家/地区
  
  role          UserRole  @default(ATTENDEE)
  status        UserStatus @default(ACTIVE)
  
  // STAFF 角色功能权限（JSON 数组，如 ["speakers","news","messages","faq"]）
  staffPermissions String?   @db.Text
  
  // 通行证相关
  passCode      String    @unique @default(uuid()) // 二维码唯一标识
  
  // 气候护照 - 唯一身份证明
  climatePassportId String? @unique // 格式: SCW2026-XXXXXX
  
  // 积分系统
  points        Int       @default(0)
  
  // 邮箱验证
  emailVerified DateTime?
  
  // 关联
  organization  Organization?
  registrations Registration[]
  checkins      CheckIn[]
  accounts      Account[]
  sessions      Session[]
  wishlist      Wishlist[]      // 收藏的活动
  pointTransactions PointTransaction[] // 积分记录
  invitationRequests InvitationRequest[] // 邀请函申请
  contactMessages ContactMessage[]     // 联系留言
  managedEvents  Event[]   @relation("EventManager")
  specialPasses  SpecialPass[]         // 特别通行证申请
  
  // 密码重置
  resetToken    String?   @unique
  resetTokenExpiry DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([email])
  @@index([passCode])
  @@index([role])
  @@map("users")
}

// 机构表
model Organization {
  id          String   @id @default(uuid())
  name        String
  logo        String?  // Logo URL
  website     String?
  description String?  @db.Text
  industry    String?  // 行业
  size        String?  // 规模
  
  // 联系信息
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  
  // 关联
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("organizations")
}

// NextAuth 账户表
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth 会话表
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth 验证令牌表
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 赛道表
model Track {
  id          String   @id @default(uuid())
  code        String   @unique // 展示编号，如 01 / 13
  name        String   // 中文名称
  nameEn      String?  // 英文名称
  description String   @db.Text
  descriptionEn String? @db.Text
  category    String   // institution | economy | foundation | accelerator
  color       String   // 主题色
  icon        String   // Lucide图标名称
  partners    Json?
  partnersEn  Json?
  order       Int      @default(0) // 排序
  
  // 关联
  events        Event[]
  relationships InstitutionRelationship[]
  knowledgeAssets KnowledgeAssetTrack[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("tracks")
}

// 活动表
model Event {
  id           String   @id @default(uuid())
  title        String
  titleEn      String?
  description  String   @db.Text
  descriptionEn String? @db.Text
  shortDesc    String?  // 简短描述
  shortDescEn  String?
  highlights   Json?    // AI 生成的中文活动亮点
  highlightsEn Json?    // AI 生成的英文活动亮点
  highlightsGeneratedAt DateTime?
  
  // 时间（支持跨天活动）
  startDate    DateTime
  endDate      DateTime
  startTime    String
  endTime      String
  
  // 地点
  venue        String   // 场馆名称
  venueEn      String?
  address      String?  // 详细地址
  addressEn    String?
  city         String?  // 城市归属，例如 Shanghai
  cityEn       String?
  
  // 媒体
  image        String?  // 封面图片
  partners     Json?
  partnersEn   Json?
  
  // 类型
  type         String   // forum | workshop | ceremony | conference | networking
  
  // 分类维度
  eventLayer   EventLayer?    // 所属层级
  hostType     EventHostType? // 主办类型
  
  // 关联
  trackId      String?
  track        Track?   @relation(fields: [trackId], references: [id])
  managerUserId String?
  manager       User?    @relation("EventManager", fields: [managerUserId], references: [id])
  
  registrations Registration[]
  eventDateSlots EventDateSlot[]
  agendaItems   AgendaItem[]
  checkins      CheckIn[]
  wishlist      Wishlist[]
  pointTransactions PointTransaction[]
  invitationRequests InvitationRequest[]
  institutions  EventInstitution[]
  knowledgeAssets KnowledgeAssetEvent[]
  posterJobs    PosterJob[]
  
  // 邀请函独立正文内容（可选，覆盖全局模板设置）
  invitationContentHtml_zh String?  @db.Text
  invitationContentHtml_en String?  @db.Text

  // 限制
  maxAttendees  Int?     // 人数限制
  requireApproval Boolean @default(false) // 报名是否需要管理员审批
  isClosed     Boolean  @default(false)  // 闭门活动，不接受报名申请
  
  // 状态
  isPublished   Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isPinned      Boolean  @default(false)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([startDate])
  @@index([trackId])
  @@index([managerUserId])
  @@index([isPinned, startDate, startTime])
  @@map("events")
}

model EventDateSlot {
  id           String   @id @default(uuid())
  eventId      String
  scheduleDate DateTime
  startTime    String
  endTime      String

  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([eventId, scheduleDate])
  @@index([eventId, scheduleDate])
  @@map("event_date_slots")
}

// 报名表
model Registration {
  id          String             @id @default(uuid())
  userId      String
  eventId     String
  status      RegistrationStatus @default(REGISTERED)
  
  // 报名信息
  notes       String?            // 备注
  dietaryReq  String?            // 饮食要求
  
  // 验码记录
  checkedInAt DateTime?          // 验码时间
  checkedInBy String?            // 验码人员ID
  checkInMethod String?          // 验码方式: QR_CODE | MANUAL
  
  // 获得的积分
  pointsEarned Int               @default(0)
  
  // 关联
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@index([checkedInBy])
  @@map("registrations")
}

// 收藏表 - 用户收藏的活动
model Wishlist {
  id          String   @id @default(uuid())
  userId      String
  eventId     String
  
  // 关联
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("wishlists")
}

// 积分交易记录
model PointTransaction {
  id          String   @id @default(uuid())
  userId      String
  
  // 积分变化
  points      Int      // 正数为获得，负数为消耗
  
  // 交易类型
  type        String   // EVENT_ATTENDANCE | EVENT_REGISTRATION | MANUAL_ADD | MANUAL_DEDUCT | BONUS
  
  // 关联信息
  eventId     String?  // 关联的活动ID（如果有）
  registrationId String? // 关联的报名ID（如果有）
  description String   // 描述
  
  // 操作人
  createdBy   String?  // 管理员ID（如果是人工操作）
  
  // 关联
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("point_transactions")
}

// 议程项表
model AgendaItem {
  id          String   @id @default(uuid())
  eventId     String
  
  // 时间
  agendaDate  DateTime
  startTime   String
  endTime     String
  
  // 内容
  title       String
  titleEn     String?
  description String?  @db.Text
  descriptionEn String? @db.Text
  type        String   // keynote | panel | workshop | sharing | launch | break | networking
  
  // 地点
  venue       String?
  
  // 嘉宾元数据（演讲主题、显示顺序等）
  speakerMeta Json?
  
  // 主持人
  moderatorId String?
  moderator   Speaker? @relation("AgendaModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  
  // 关联
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  speakers    Speaker[]
  
  order       Int      @default(0) // 排序
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([eventId])
  @@index([eventId, agendaDate])
  @@index([moderatorId])
  @@map("agenda_items")
}

// 嘉宾表
model Speaker {
  id              String   @id @default(uuid())
  slug            String?  @unique  // URL 友好标识符，如 "wu-changhua"
  salutation      String?  // 称谓: Dr. / Mr. / Ms. / Prof. 等
  name            String
  nameEn          String?
  avatar          String?
  title           String   // 职位
  titleEn         String?
  organization    String   // 机构
  organizationEn  String?
  organizationLogo String?
  bio             String?  @db.Text
  bioEn           String?  @db.Text
  // 人物摘要（显示在 Hero 区域的精简描述，区别于完整 bio）
  summary         String?  @db.Text
  summaryEn       String?  @db.Text
  // 国家/地区
  countryOrRegion   String?
  countryOrRegionEn String?
  // 与上海气候周的关联描述
  relevanceToShcw   String?  @db.Text
  relevanceToShcwEn String?  @db.Text
  // 专业领域标签，JSON 数组存储，如 ["气候金融","绿色供应链"]
  expertiseTags   Json?
  email           String?
  linkedin        String?
  twitter         String?
  website         String?
  
  // 是否为Keynote
  isKeynote       Boolean  @default(false)
  // 是否在前端公开展示
  isVisible       Boolean  @default(true)
  
  // 关联机构（可选，链接到 Institution 表）
  institutionId   String?
  institution     Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  // 关联
  agendaItems     AgendaItem[]
  moderatedItems  AgendaItem[] @relation("AgendaModerator")
  roles           SpeakerRole[]
  knowledgeAssets KnowledgeAssetSpeaker[]
  posterJobs      PosterJob[]
  
  order           Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("speakers")
}

// 嘉宾历史职务表
model SpeakerRole {
  id             String   @id @default(uuid())
  speakerId      String
  speaker        Speaker  @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  title          String
  titleEn        String?
  organization   String
  organizationEn String?
  startYear      Int?     // 开始年份
  endYear        Int?     // 结束年份，isCurrent=true 时为 null
  isCurrent      Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("speaker_roles")
}

// 入场记录表
model CheckIn {
  id          String   @id @default(uuid())
  userId      String
  eventId     String?
  
  // 扫码信息
  scannedBy   String   // 工作人员ID
  scannedAt   DateTime @default(now())
  method      String   // QR_CODE | MANUAL
  
  // 关联
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([eventId])
  @@index([scannedBy])
  @@map("checkins")
}

// 赞助商表
model Sponsor {
  id          String   @id @default(uuid())
  name        String
  nameEn      String?
  logo        String
  website     String?
  description String?  @db.Text
  descriptionEn String? @db.Text
  
  // 赞助级别
  tier        String   // platinum | gold | silver | bronze | partner
  
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  showOnHomepage Boolean @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("sponsors")
}

// 赞助方案详情表（后台可编辑的赞助方案信息）
model CooperationPlan {
  id          String   @id @default(uuid())
  
  // 基本信息
  tierType    String   @unique  // platinum | gold | silver | bronze | partner
  name        String   // 中文名称
  nameEn      String   // 英文名称
  description String?  @db.Text
  descriptionEn String? @db.Text
  price       String?  // 价格范围，如 ¥300,000-500,000
  
  // 特性列表（JSON 数组）
  features    Json     // 中文特性列表: ["feature1", "feature2", ...]
  featuresEn  Json     // 英文特性列表: ["feature1", "feature2", ...]
  
  // 排序
  order       Int      @default(0)
  
  // 状态
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("sponsorship_tiers")
}

// 新闻表
model News {
  id          String   @id @default(uuid())
  title       String
  titleEn     String?
  slug        String   @unique
  excerpt     String?  // 摘要
  excerptEn   String?
  content     String   @db.Text
  contentEn   String?  @db.Text
  coverImage  String?
  
  // 状态
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  
  // 元数据
  views       Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([slug])
  @@index([publishedAt])
  @@map("news")
}

// 站点内容（关于我们等可编辑区块）
model SiteContent {
  id          String   @id @default(uuid())
  key         String   @unique  // e.g. "about_us", "mission"
  title       String?
  titleEn     String?
  subtitle    String?
  subtitleEn  String?
  description String?  @db.Text
  descriptionEn String? @db.Text
  extra       Json?    // 扩展字段
  
  updatedAt   DateTime @updatedAt
  
  @@map("site_contents")
}

  // 常见问题
  model FaqItem {
    id             String   @id @default(uuid())
    category       String
    categoryEn     String?
    question       String
    questionEn     String?
    summary        String?  @db.Text
    summaryEn      String?  @db.Text
    answer         String   @db.Text
    answerEn       String?  @db.Text
    attachmentUrl  String?
    attachmentName String?
    isPinned       Boolean  @default(false)
    isPublished    Boolean  @default(true)
    sortOrder      Int      @default(0)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    @@index([category, isPublished, isPinned, sortOrder])
    @@map("faq_items")
  }

// 邀请函申请表
model InvitationRequest {
  id              String           @id @default(uuid())
  userId          String
  
  // 受邀嘉宾信息
  salutation      String?          // 称谓: Dr. / Mr. / Ms. / Prof. 等
  guestName       String           // 嘉宾姓名
  guestTitle      String?          // 嘉宾职位
  guestOrg        String?          // 嘉宾机构
  guestEmail      String?          // 嘉宾邮箱
  language        String           @default("zh") // 邀请函语言: zh | en
  
  // 关联活动（可选，指定具体活动的邀请函）
  eventId         String?
  
  // 参会说明
  purpose         String?          @db.Text // 参会目的或说明
  notes           String?          @db.Text // 备注
  customMainContent String?        @db.Text // 用户自定义邀请函正文（纯文本，优先级最高）

  // AI 优化后的邀请函正文缓存（仅在 purpose 填写时生成，customMainContent 优先）
  aiEnhancedBodyZh String?         @db.Text
  aiEnhancedBodyEn String?         @db.Text
  
  // 英文邀请函签名预设
  signaturePresetId String?        // 英文邀请函签名预设ID（仅语言为 en 时生效）
  useStamp          Boolean        @default(false) // 是否在落款处加盖公章（仅中文邀请函）

  // 状态与文件
  status          InvitationStatus @default(PENDING)
  letterFileUrl   String?          // 管理员上传的邀请函文件URL
  rejectReason    String?          // 拒绝原因
  
  // 关联
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event           Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([eventId])
  @@map("invitation_requests")
}

// 联系留言表
model ContactMessage {
  id          String               @id @default(uuid())
  
  // 发送者信息
  name        String
  email       String
  phone       String?
  organization String?             // 机构名称
  userId      String?              // 关联已注册用户
  user        User?                @relation(fields: [userId], references: [id])
  
  // 内容
  category    ContactCategory      @default(GENERAL)
  subject     String
  message     String               @db.Text
  metadata    Json?                // 存储合作级别、媒体类型等附加信息
  
  // 处理状态
  status      ContactMessageStatus @default(PENDING)
  adminReply  String?              @db.Text // 管理员回复内容
  adminNotes  String?              @db.Text // 管理员内部备注
  repliedAt   DateTime?
  repliedBy   String?              // 回复人ID
  
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  
  @@index([category])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@map("contact_messages")
}

// 特别通行证申请状态
enum SpecialPassStatus {
  PENDING   // 待审核
  APPROVED  // 已批准
  REJECTED  // 已拒绝
}

// 特别通行证入境方式
enum SpecialPassEntryType {
  DOMESTIC       // 从上海市区进入
  INTERNATIONAL  // 从国际航班（浦东机场）直接进入
}

// 特别通行证申请表
model SpecialPass {
  id            String              @id @default(uuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  entryType     SpecialPassEntryType // 入境方式
  status        SpecialPassStatus    @default(PENDING)
  
  // 通用字段
  country       String              // 国家/地区
  name          String              // 姓名
  birthDate     String              // 出生日期
  gender        String              // 性别: M / F
  docNumber     String              // 证件号码
  docValidFrom  String              // 证件有效期开始
  docValidTo    String              // 证件有效期结束
  docPhoto      String?  @db.Text   // 证件照片 (base64)
  docPhotoBack  String?  @db.Text   // 证件反面照片 (base64)
  photo         String?  @db.Text   // 近期免冠照片 (base64)
  organization  String?             // 工作单位
  jobTitle      String?             // 职务
  
  // 境外人士额外字段
  docType       String?             // 证件类型（外交护照/公务护照/普通护照等）
  email         String?             // 电子邮箱
  phoneArea     String?             // 联系电话区号
  phone         String?             // 联系电话
  
  // 境内人士额外字段
  contactMethod String?             // 联系方式类型（手机/邮箱等）
  contactValue  String?             // 联系方式值
  
  // 管理
  adminNotes    String?  @db.Text
  reviewedBy    String?
  reviewedAt    DateTime?
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([entryType])
  @@map("special_passes")
}

// 机构/伙伴表（公开展示用，与 Organization 用户注册表无关）
model Institution {
  id              String   @id @default(uuid())
  slug            String   @unique  // URL 友好唯一标识
  name            String
  nameEn          String?
  shortName       String?
  shortNameEn     String?
  logo            String?  // Logo URL
  website         String?
  // 机构类型: ngo | gov | corp | academic | media | community | foundation | intergovernmental
  orgType         String?
  countryOrRegion   String?
  countryOrRegionEn String?
  description     String?  @db.Text
  descriptionEn   String?  @db.Text
  collaborationBg   String?  @db.Text  // 合作背景（中）
  collaborationBgEn String?  @db.Text  // 合作背景（英）

  isActive        Boolean  @default(true)
  order           Int      @default(0)

  // 关联
  relationships   InstitutionRelationship[]
  events          EventInstitution[]
  speakers        Speaker[]
  knowledgeAssets KnowledgeAssetInstitution[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([isActive, order])
  @@map("institutions")
}

// 机构合作关系表（年度/赛道/专项合作记录）
model InstitutionRelationship {
  id            String      @id @default(uuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  // 关系类型: organizer | co_organizer | knowledge_partner | strategic_partner |
  //           sponsor | track_leader | venue_partner | media_partner |
  //           community_partner | supporting_org
  type          String

  // 合作范围: annual | track | event
  scope         String      @default("annual")

  // 赞助级别（仅 type=sponsor 时有意义）
  sponsorLevel  String?     // platinum | gold | silver | bronze

  // 关联赛道（scope=track 时）
  trackId       String?
  track         Track?      @relation(fields: [trackId], references: [id], onDelete: SetNull)

  // 展示控制
  // displaySection: strategic | knowledge | sponsor | none
  displaySection  String?
  showOnHomepage  Boolean   @default(false)
  priority        Int       @default(0)

  // 合作期
  startYear       Int?
  endYear         Int?
  isCurrent       Boolean   @default(true)

  // 权益内容（JSON 快速存储）
  benefitsJson    Json?

  // 备注
  note            String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([institutionId])
  @@index([type])
  @@index([scope])
  @@index([trackId])
  @@index([showOnHomepage, priority])
  @@map("institution_relationships")
}

// 活动-机构 多对多关联表
model EventInstitution {
  eventId       String
  institutionId String
  event         Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  role          String?     // organizer | co_organizer | supporter 等
  order         Int         @default(0)

  @@id([eventId, institutionId])
  @@index([eventId])
  @@index([institutionId])
  @@map("event_institutions")
}

model KnowledgeAsset {
  id              String            @id @default(uuid())
  title           String
  titleEn         String?
  subtitle        String?
  subtitleEn      String?
  slug            String            @unique
  type            KnowledgeAssetType
  language        String            @default("zh") // zh | en | bilingual
  coverImage      String?
  publishDate     DateTime?

  summary         String?           @db.Text
  summaryEn       String?           @db.Text
  content         String?           @db.Text
  contentEn       String?           @db.Text
  keyPoints       Json?
  keyPointsEn     Json?
  references      Json?

  // 扩展字段：章节划分和推荐信息
  chapters        Json?             // [{title, subtitle, content, keyPoints, pageStart, pageEnd}, ...]
  chaptersEn      Json?
  recommendations String?           @db.Text // 推荐阅读/相关资源
  recommendationsEn String?         @db.Text
  tags            String?           // 逗号分隔的标签
  tagsEn          String?
  author          String?           // 作者文字署名（补充 speakers 关联）

  // 精选引语
  pullQuote       String?           @db.Text
  pullQuoteEn     String?           @db.Text
  pullQuoteCaption String?
  pullQuoteCaptionEn String?

  // 封底关于我们（可选，优先走全局 SiteContent）
  aboutUs         String?           @db.Text
  aboutUsEn       String?           @db.Text

  fileUrl         String?
  fileFormat      String?
  fileSize        Int?
  accessType      AccessType        @default(PUBLIC)
  price           Decimal?          @db.Decimal(10, 2)
  currency        String?           @default("CNY")
  downloadEnabled Boolean           @default(true)
  previewEnabled  Boolean           @default(true)
  previewPages    Int?
  watermark       Boolean           @default(false)

  doi             String?
  citation        String?           @db.Text

  isFeatured      Boolean           @default(false)
  isHighlight     Boolean           @default(false)
  sortOrder       Int               @default(0)
  status          PublishStatus     @default(DRAFT)

  // 文档生成配置
  primaryTemplateId String?         // 关联的正式文档模板
  webTemplateId     String?         // 关联的网页展示模板

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  events          KnowledgeAssetEvent[]
  institutions    KnowledgeAssetInstitution[]
  speakers        KnowledgeAssetSpeaker[]
  tracks          KnowledgeAssetTrack[]
  versions        KnowledgeAssetVersion[]
  posterJobs      PosterJob[]
  generationJobs  KnowledgeGenerationJob[]

  @@index([slug])
  @@index([status, publishDate])
  @@index([type, sortOrder])
  @@map("knowledge_assets")
}

model KnowledgeAssetVersion {
  id               String         @id @default(uuid())
  knowledgeAssetId String
  knowledgeAsset   KnowledgeAsset @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)

  versionLabel     String
  changeLog        String?        @db.Text
  contentSnapshot  String?        @db.Text
  fileUrl          String?

  createdAt        DateTime       @default(now())

  @@index([knowledgeAssetId])
  @@map("knowledge_asset_versions")
}

model KnowledgeAssetEvent {
  knowledgeAssetId String
  eventId          String
  knowledgeAsset   KnowledgeAsset @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([knowledgeAssetId, eventId])
  @@index([eventId])
  @@map("knowledge_asset_events")
}

model KnowledgeAssetInstitution {
  knowledgeAssetId String
  institutionId    String
  knowledgeAsset   KnowledgeAsset @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  institution      Institution    @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@id([knowledgeAssetId, institutionId])
  @@index([institutionId])
  @@map("knowledge_asset_institutions")
}

model KnowledgeAssetSpeaker {
  knowledgeAssetId String
  speakerId        String
  knowledgeAsset   KnowledgeAsset @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  speaker          Speaker        @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([knowledgeAssetId, speakerId])
  @@index([speakerId])
  @@map("knowledge_asset_speakers")
}

model KnowledgeAssetTrack {
  knowledgeAssetId String
  trackId          String
  knowledgeAsset   KnowledgeAsset @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  track            Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([knowledgeAssetId, trackId])
  @@index([trackId])
  @@map("knowledge_asset_tracks")
}

// 知识成果文档模板配置
model KnowledgeTemplate {
  id              String                  @id @default(uuid())
  name            String                  // 模板名称
  nameEn          String?
  description     String?                 @db.Text
  code            String                  @unique  // 模板代码，如 formal_doc_v1
  templateType    KnowledgeTemplateType   // FORMAL_DOCUMENT | WEBPAGE_DISPLAY
  isActive        Boolean                 @default(true)
  isDefault       Boolean                 @default(false)
  sortOrder       Int                     @default(0)

  // 模板配置（JSON格式）
  config          Json                    // 包含样式、布局、字段映射等配置
  
  // 对于正式文档模板
  documentFormat  String?                 // pdf | docx
  includeElements Json?                   // {includeCover, includeTableOfContents, includeWatermark, etc}
  
  // 对于网页展示模板
  componentType   String?                 // standard | minimal | detailed
  
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  generationJobs  KnowledgeGenerationJob[]

  @@index([templateType, isActive, isDefault])
  @@map("knowledge_templates")
}

// 知识成果生成任务
model KnowledgeGenerationJob {
  id               String                @id @default(uuid())
  knowledgeAssetId String
  knowledgeAsset   KnowledgeAsset        @relation(fields: [knowledgeAssetId], references: [id], onDelete: Cascade)
  
  templateId       String
  template         KnowledgeTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  
  jobType          String                // document | webpage | both
  status           String                @default("PENDING")  // PENDING | RUNNING | COMPLETED | FAILED
  progress         Int                   @default(0)  // 0-100
  
  outputUrl        String?               // 生成文件的URL或页面链接
  outputFormat     String?               // PDF | DOCX | HTML
  
  errorMessage     String?               @db.Text
  
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  completedAt      DateTime?

  @@index([knowledgeAssetId, templateId])
  @@index([status, createdAt])
  @@map("knowledge_generation_jobs")
}

model PosterTemplate {
  id            String             @id @default(uuid())
  templateName  String
  templateType  PosterTemplateType
  aspectRatio   String             // 1:1 | 4:5 | 16:9
  layoutJson    Json
  background    String?
  fontConfig    Json?
  isActive      Boolean            @default(true)
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  jobs          PosterJob[]

  @@index([templateType, isActive, sortOrder])
  @@map("poster_templates")
}

model PosterJob {
  id               String         @id @default(uuid())
  templateId       String
  template         PosterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  knowledgeAssetId String?
  knowledgeAsset   KnowledgeAsset? @relation(fields: [knowledgeAssetId], references: [id], onDelete: SetNull)

  eventId          String?
  event            Event?         @relation(fields: [eventId], references: [id], onDelete: SetNull)

  speakerId        String?
  speaker          Speaker?       @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  locale           String         @default("zh")
  outputFormat     String         @default("png") // png | pdf
  outputUrl        String?
  status           PosterJobStatus @default(PENDING)
  errorMessage     String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([templateId])
  @@index([knowledgeAssetId])
  @@index([eventId])
  @@index([speakerId])
  @@index([status, createdAt])
  @@map("poster_jobs")
}

// OpenClaw API 密钥表
model ApiKey {
  id          String    @id @default(uuid())
  name        String    // 名称，如 "OpenClaw Production"
  keyHash     String    @unique // SHA-256 哈希值（原始 key 不落库）
  keyPrefix   String    // 前8位明文，用于展示识别，如 "sk_oc_ab"
  permissions Json      // 权限数组: ["events:read","events:write","speakers:read",...]
  ipAllowlist Json?     // IP 白名单数组，null = 不限制
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  note        String?   // 备注说明

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@index([isActive])
  @@map("api_keys")
}
